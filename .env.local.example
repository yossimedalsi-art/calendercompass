NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Required for every server API route (/api/book, /api/admin, /api/cancel, /api/settings, /api/availability).
# Without this, those routes throw and bookings/admin actions fail.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# Required to actually send WhatsApp confirmations/reminders. Without these,
# messages are silently skipped (booking still succeeds).
WHATSAPP_TOKEN=your_whatsapp_cloud_api_token
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id

# Owner's WhatsApp number (with country code, digits only, e.g. 972501234567).
# Without this, the owner is never notified of new bookings.
OWNER_WHATSAPP_PHONE=972501234567

# Protects /api/cron/reminders from public access in production.
CRON_SECRET=some_random_secret
